# ─── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6                # swap to claude-opus-4-7 for harder pages
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1                         # low = deterministic browser actions

# ─── CAPTCHA SOLVING ──────────────────────────────────────────────────────────
CAPTCHA_PROVIDER=2captcha                   # options: 2captcha | capsolver | manual
CAPTCHA_API_KEY=your_2captcha_key_here
CAPTCHA_TIMEOUT_SECONDS=60                  # how long to wait for CAPTCHA solution
CAPTCHA_MAX_RETRIES=3

# ─── BROWSER ──────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=false                      # true in prod, false for debugging
BROWSER_SLOW_MO_MS=80                       # slow down actions (ms) — helps avoid bot detect
BROWSER_TIMEOUT_MS=30000                    # page load timeout
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=800
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ─── SARATHI PORTAL ───────────────────────────────────────────────────────────
SARATHI_BASE_URL=https://sarathi.parivahan.gov.in/sarathiservice
SARATHI_DEFAULT_STATE=DL                    # state code e.g. DL=Delhi, MH=Maharashtra
SARATHI_SESSION_TIMEOUT_MINUTES=25          # portal times out at 30min; we restart at 25

# ─── STATE STORAGE ────────────────────────────────────────────────────────────
STATE_BACKEND=sqlite                        # options: sqlite | redis
SQLITE_DB_PATH=./data/agent_state.db
REDIS_URL=redis://localhost:6379/0          # used if STATE_BACKEND=redis

# ─── LEARNING STORE ───────────────────────────────────────────────────────────
LEARNING_DB_PATH=./data/learning_store.db  # grows over time, do not delete
SCENARIO_SIMILARITY_THRESHOLD=0.85         # cosine similarity to match past scenarios
MAX_AUTO_RETRY_WITH_LEARNING=3             # retries using learned solutions before human help

# ─── HUMAN IN THE LOOP ────────────────────────────────────────────────────────
HUMAN_LOOP_BACKEND=webhook                  # options: webhook | firebase | polling
HUMAN_LOOP_WEBHOOK_URL=https://your-app.com/api/agent/human-help
HUMAN_LOOP_TIMEOUT_MINUTES=30              # how long to wait for human before escalating
FIREBASE_CREDENTIALS_PATH=./firebase-creds.json   # only needed if HUMAN_LOOP_BACKEND=firebase

# ─── OTP RELAY ────────────────────────────────────────────────────────────────
OTP_WAIT_TIMEOUT_SECONDS=600               # 10 min window for user to enter OTP
OTP_RELAY_POLL_INTERVAL_SECONDS=3

# ─── OCR ──────────────────────────────────────────────────────────────────────
OCR_PROVIDER=claude                         # options: claude | tesseract | aws_textract
AWS_TEXTRACT_REGION=ap-south-1              # only if OCR_PROVIDER=aws_textract
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── IMAGE PROCESSING ─────────────────────────────────────────────────────────
PHOTO_MAX_SIZE_KB=20                        # Sarathi max photo size
SIGNATURE_MAX_SIZE_KB=10                    # Sarathi max signature size
PHOTO_WIDTH_PX=200
PHOTO_HEIGHT_PX=200

# ─── API SERVER ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-in-production

# ─── AGENT BEHAVIOUR ──────────────────────────────────────────────────────────
MAX_STEPS_PER_JOB=100                       # safety cap — abort if exceeded
STUCK_THRESHOLD_RETRIES=3                   # retries before declaring "stuck"
SCREENSHOT_ON_EVERY_STEP=true              # set false to save cost in prod
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
